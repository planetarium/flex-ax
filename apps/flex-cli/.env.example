# 인증 모드: "credentials" | "sso" | "playwriter"
#   credentials: 이메일/비밀번호 (FLEX_EMAIL, FLEX_PASSWORD 필수)
#   sso: 브라우저 열어서 수동 로그인
#   playwriter: Playwriter Extension CDP relay로 기존 Chrome 세션 재사용 (로그인 불필요)
#              Extension 활성화 후 대상 탭에서 아이콘 클릭 필요
# AUTH_MODE=credentials

# flex 로그인 정보 (AUTH_MODE=credentials일 때 필수)
FLEX_EMAIL=your-email@example.com
FLEX_PASSWORD=your-password

# flex 서비스 URL (기본값: https://flex.team)
# FLEX_BASE_URL=https://flex.team

# 수집 데이터 저장 경로 (기본값: ./output)
# OUTPUT_DIR=./output

# API 카탈로그 파일 경로 (기본값: ./output/api-catalog.json)
# CATALOG_PATH=./output/api-catalog.json

# 요청 간 딜레이 (밀리초, 기본값: 0)
# 동시성으로 throttling을 대체하므로 평소엔 0. 공유 IP 등 보수적 환경에서만 사용.
# REQUEST_DELAY_MS=0

# 인스턴스/템플릿 상세 fetch 동시 워커 수 (기본값: 16)
# probe 실측: c=64까지 429 0건, 그 이상은 latency만 증가. 32까지는 안전하게 올릴 수 있음.
# CONCURRENCY=16

# 한 문서 내 첨부파일 다운로드 동시 수 (기본값: 4)
# ATTACHMENT_CONCURRENCY=4

# approval-document 검색 1회 호출의 size (기본값: 1000)
# SEARCH_PAGE_SIZE=1000

# 요청 실패 시 최대 재시도 횟수 (기본값: 3, 429는 Retry-After 존중)
# MAX_RETRIES=3

# 첨부파일 다운로드 여부 (기본값: true)
# DOWNLOAD_ATTACHMENTS=true

# 브라우저 headless 모드 (기본값: true, SSO 모드에서는 무시됨)
# HEADLESS=true
