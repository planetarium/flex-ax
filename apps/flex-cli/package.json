{
  "name": "flex-ax",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "flex HR SaaS AX CLI - discover, crawl, and manage flex data",
  "bin": {
    "flex-ax": "./dist/cli.js"
  },
  "scripts": {
    "start": "tsx src/cli.ts",
