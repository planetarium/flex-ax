{
  "name": "flex-ax",
  "version": "0.8.2",
  "private": true,
  "type": "module",
  "description": "flex HR SaaS AX CLI - discover, crawl, and manage flex data",
  "bin": {
    "flex-ax": "./dist/cli.js"
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "scripts": {
    "start": "bun run src/cli.ts",
    "crawl": "bun run src/cli.ts crawl",
    "install-skills": "bun run src/cli.ts install-skills",
    "build": "tsc -p tsconfig.build.json && node scripts/postbuild.cjs",
    "build:exe": "bun build --compile src/cli.ts --outfile bun-dist/flex-ax",
    "test": "bun test",
    "lint": "tsc --noEmit",
    "clean": "rimraf output dist"
  },
  "dependencies": {
    "@napi-rs/keyring": "^1.1.7",
    "commander": "^14.0.3",
    "dotenv": "^16.4.7",
    "semver": "^7.7.4",
    "yaml": "^2.6.1",
    "zod": "^3.24.2"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "devDependencies": {
    "@1password/sdk": "^0.4.0",
    "@types/bun": "^1.1.0",
    "@types/node": "^22.13.5",
    "@types/semver": "^7.7.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3"
  }
}
