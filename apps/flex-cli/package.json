{
  "name": "flex-ax",
  "version": "0.6.0",
  "private": true,
  "type": "module",
  "description": "flex HR SaaS AX CLI - discover, crawl, and manage flex data",
  "bin": {
    "flex-ax": "./dist/flex-ax"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "bun src/cli.ts",
    "crawl": "bun src/cli.ts crawl",
    "install-skills": "bun src/cli.ts install-skills",
    "build": "bun build ./src/cli.ts --compile --outfile ./dist/flex-ax --external electron --external 'chromium-bidi/*' --external 'chromium-bidi'",
    "test": "bun test",
    "lint": "tsc --noEmit",
    "clean": "rimraf output dist"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "playwright": "^1.50.1",
    "semver": "^7.7.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/node": "^22.13.5",
    "@types/semver": "^7.7.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3"
  }
}
